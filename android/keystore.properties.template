# Release signing config. Copy to `android/keystore.properties` (gitignored) and
# fill in real values. Generate the keystore first:
#
#   keytool -genkeypair -v -keystore android/app/release.keystore \
#     -alias music -keyalg RSA -keysize 2048 -validity 10000
#
# storeFile is resolved relative to android/app/.
storeFile=release.keystore
storePassword=CHANGE_ME
keyAlias=music
keyPassword=CHANGE_ME
