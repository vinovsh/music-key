# Normalize line endings: store everything as LF in the repo.
# Git checks out with the platform's native endings but commits LF.
* text=auto eol=lf

# Windows-native files keep CRLF.
*.bat       text eol=crlf
*.cmd       text eol=crlf
gradlew.bat text eol=crlf

# Shell scripts must stay LF even on Windows checkout.
*.sh    text eol=lf
gradlew text eol=lf

# Binary assets — never touch line endings or diff as text.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.sf2   binary
*.mid   binary
*.wav   binary
*.m4a   binary
*.aac   binary
*.mp3   binary
*.ttf   binary
*.otf   binary
*.keystore binary
*.jar   binary
*.apk   binary
*.aab   binary
